rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Checking custom claims set by the Firebase Admin SDK to avoid extra document reads
      return isAuthenticated() && 
        (request.auth.token.role == 'admin' || request.auth.token.role == 'superadmin');
    }

    function isValidProduct(productData) {
      return productData.price >= 0 &&
             productData.price <= 100000 &&
             productData.title.size() > 0 &&
             productData.title.size() <= 200 &&
             productData.imageUrls.size() >= 1 &&
             productData.imageUrls.size() <= 10;
    }

    // Users
    match /users/{userId} {
      // Allow public read of individual user profiles for display (e.g. seller info)
      allow get: if true;
      allow read, list: if isOwner(userId) || isAdmin() || (resource != null && (resource.data.accountType == 'seller' || resource.data.role == 'seller'));
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      // Only superadmins should be able to delete user accounts permanently
      allow delete: if isAdmin();
      
      // Allow users to manage their favorite categories
      match /favorite_categories/{docId} {
        allow read, write: if isOwner(userId);
      }

      // Allow users to manage their favorite products
      match /favorites/{docId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Products
    match /products/{productId} {
      allow read: if resource.data.status == 'available' || 
                  (isAuthenticated() && resource.data.sellerId == request.auth.uid) || 
                  isAdmin();
      
      allow create: if isAuthenticated() && 
                     request.resource.data.sellerId == request.auth.uid &&
                     isValidProduct(request.resource.data);
      
      allow update: if isAuthenticated() && 
                     (resource.data.sellerId == request.auth.uid || isAdmin()) &&
                     (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['sellerId'])) &&
                     isValidProduct(request.resource.data);

      // Explicitly DENY permanent delete through client SDK for safety.
      // All deletions must be "soft deletes" performed via update.
      allow delete: if false;
    }

    // Ads - Public Read, Admin Write
    match /ads/{adId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      // Reviews should be created via server action to verify order completion and prevent spam
      allow create: if false; 
      allow update, delete: if isAdmin();
    }
    
    // Wanted Listings (WTB)
    match /wanted_listings/{listingId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      // Explicitly DENY permanent delete through client SDK for safety.
      // All deletions must be "soft deletes" performed via update.
      allow delete: if false;
    }
    
    // Bids
    match /bids/{bidId} {
       allow read: if isAuthenticated() && (resource.data.bidderId == request.auth.uid || isAdmin());
       allow create: if isAuthenticated() && request.resource.data.bidderId == request.auth.uid;
       allow update: if isAdmin();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
      // Notifications must ALWAYS be created via Server Actions / Admin SDK
      allow create: if false; 
      allow update: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
    }

    // Settings
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      allow read: if (isAuthenticated() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid)) || isAdmin();
      // Orders must ALWAYS be created via createOrderAction server action for calculation integrity
      allow create: if false;
      allow update: if isAdmin();
    }

    // Activity Logs - System only
    match /activity_logs/{logId} {
      allow read, write: if false;
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Card Imports for SamCam
    match /card_imports/{importId} {
      allow read, write: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid || request.resource.data.userId == request.auth.uid) || isAdmin();
    }

    // Conversations and Messages
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read, create: if isAuthenticated() && 
          request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participants;
      }
    }
  }
}
